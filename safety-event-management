<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Managing Safety Events: Case Discussion Series</title>
<style>
  :root{--edgewood-red:#BB0000;--black:#000000;--white:#FFFFFF;--dark-gold:#C8932B;--warm-grey:#F0EEEB;--dark-web-grey:#58595B;--slate-blue:#5794AD;--light-grey:#C2C6C8;}
  *{box-sizing:border-box;}
  body{font-family:'Source Sans Pro',Arial,sans-serif;background:var(--warm-grey);color:var(--black);margin:0;padding:0;line-height:1.6;}
  header{background:var(--black);color:var(--white);padding:32px 20px;text-align:center;}
  header h1{font-family:'Spectral',Georgia,serif;margin:0 0 8px;font-size:2rem;letter-spacing:.5px;}
  header p{margin:0;color:var(--light-grey);font-size:1rem;}
  .accent-bar{height:6px;background:var(--edgewood-red);}
  .wrap{max-width:960px;margin:0 auto;padding:32px 20px 60px;}

  /* Landing page */
  .intro-card{background:var(--white);border:1px solid var(--light-grey);border-radius:6px;padding:28px 32px;margin-bottom:28px;box-shadow:0 2px 6px rgba(0,0,0,.05);}
  .intro-card h2{font-family:'Spectral',Georgia,serif;margin:0 0 12px;font-size:1.4rem;}
  .intro-card p{margin:0 0 10px;font-size:.97rem;}
  .intro-card p:last-child{margin:0;}

  .case-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px;margin-bottom:28px;}
  .case-card{background:var(--white);border:1px solid var(--light-grey);border-radius:6px;padding:18px 20px;cursor:pointer;transition:all .15s ease;box-shadow:0 1px 4px rgba(0,0,0,.04);}
  .case-card:hover{border-color:var(--slate-blue);box-shadow:0 3px 10px rgba(0,0,0,.1);}
  .case-card.completed{border-left:4px solid #2e7d32;}
  .case-card.in-progress{border-left:4px solid var(--dark-gold);}
  .case-num{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--dark-web-grey);margin-bottom:6px;}
  .case-name{font-family:'Spectral',Georgia,serif;font-size:1.05rem;margin:0 0 6px;color:var(--black);}
  .case-meta{font-size:.82rem;color:var(--dark-web-grey);}
  .case-badge{display:inline-block;font-size:.72rem;font-weight:700;padding:2px 8px;border-radius:3px;margin-top:8px;}
  .badge-done{background:#eaf5ea;color:#2e7d32;}
  .badge-progress{background:#fff8e6;color:#b87400;}
  .badge-new{background:var(--warm-grey);color:var(--dark-web-grey);}

  .download-all-btn{background:var(--black);color:var(--white);border:none;font-family:inherit;font-size:.95rem;font-weight:700;padding:13px 28px;border-radius:5px;cursor:pointer;display:flex;align-items:center;gap:10px;}
  .download-all-btn:hover{background:#333;}
  .download-all-btn svg{width:18px;height:18px;fill:var(--white);}

  .progress-summary{background:var(--white);border:1px solid var(--light-grey);border-radius:6px;padding:16px 20px;margin-bottom:24px;display:flex;align-items:center;gap:20px;flex-wrap:wrap;}
  .prog-stat{text-align:center;}
  .prog-stat .num{font-family:'Spectral',Georgia,serif;font-size:1.8rem;font-weight:700;color:var(--edgewood-red);display:block;}
  .prog-stat .lbl{font-size:.78rem;color:var(--dark-web-grey);text-transform:uppercase;letter-spacing:.5px;}
  .prog-bar-wrap{flex:1;min-width:160px;}
  .prog-bar-label{font-size:.82rem;color:var(--dark-web-grey);margin-bottom:4px;}
  .prog-bar-bg{background:var(--light-grey);border-radius:4px;height:10px;overflow:hidden;}
  .prog-bar-fill{background:var(--edgewood-red);height:100%;transition:width .4s ease;}

  /* Case viewer */
  #case-viewer{display:none;}
  .viewer-header{background:var(--black);color:var(--white);padding:14px 20px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;}
  .viewer-header h2{font-family:'Spectral',Georgia,serif;font-size:1.1rem;margin:0;}
  .back-btn{background:transparent;border:1px solid var(--light-grey);color:var(--white);font-family:inherit;font-size:.85rem;padding:6px 14px;border-radius:4px;cursor:pointer;}
  .back-btn:hover{background:rgba(255,255,255,.1);}
  iframe{width:100%;border:none;display:block;}

  /* Download log modal */
  .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:200;display:none;align-items:center;justify-content:center;}
  .modal-overlay.show{display:flex;}
  .modal{background:var(--white);border-radius:8px;padding:28px 32px;max-width:600px;width:90%;max-height:85vh;overflow-y:auto;}
  .modal h3{font-family:'Spectral',Georgia,serif;margin:0 0 12px;font-size:1.3rem;}
  .modal p{font-size:.95rem;margin:0 0 16px;}
  .modal-btn-row{display:flex;gap:12px;flex-wrap:wrap;margin-top:18px;}
  .modal-primary{background:var(--edgewood-red);color:var(--white);border:none;font-family:inherit;font-weight:700;padding:11px 24px;border-radius:5px;cursor:pointer;}
  .modal-primary:hover{background:#930000;}
  .modal-secondary{background:transparent;border:2px solid var(--dark-web-grey);color:var(--dark-web-grey);font-family:inherit;font-weight:700;padding:9px 22px;border-radius:5px;cursor:pointer;}
  .modal-secondary:hover{background:var(--dark-web-grey);color:var(--white);}
</style>
</head>
<body>

<header>
  <h1>Managing Safety Events</h1>
  <p>HCA 680: Integrity of Care &mdash; Patient Safety and Risk &middot; Case Discussion Series</p>
</header>
<div class="accent-bar"></div>

<!-- LANDING PAGE -->
<div id="landing" class="wrap">

  <div class="intro-card">
    <h2>About This Case Series</h2>
    <p>This series of 15 cases walks you through the Safety Event Classification (SEC) framework used in healthcare organizations to identify, classify, and respond to patient safety events. Each case presents a clinical vignette and guides you through five discussion points: identifying deviations from Generally Accepted Performance Standards (GAPS), determining whether the deviation reached the patient, scoring the level of harm, determining sentinel event status, and applying the SAC Priority Matrix.</p>
    <p>Cases may be completed in any order. Your progress and responses are saved in this session. Use the Download Log buttons to generate a record of your work to submit.</p>
  </div>

  <div class="progress-summary" id="prog-summary">
    <div class="prog-stat"><span class="num" id="prog-done">0</span><span class="lbl">Completed</span></div>
    <div class="prog-stat"><span class="num" id="prog-total">15</span><span class="lbl">Total Cases</span></div>
    <div class="prog-bar-wrap">
      <div class="prog-bar-label">Overall Progress</div>
      <div class="prog-bar-bg"><div class="prog-bar-fill" id="prog-bar" style="width:0%;"></div></div>
    </div>
    <button class="download-all-btn" id="download-all-btn" onclick="downloadAllLogs()">
      <svg viewBox="0 0 24 24"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
      Download Complete Response Log
    </button>
  </div>

  <div class="case-grid" id="case-grid"></div>

</div>

<!-- CASE VIEWER -->
<div id="case-viewer">
  <div class="viewer-header">
    <button class="back-btn" onclick="returnToLanding()">&#8592; All Cases</button>
    <h2 id="viewer-title">Case</h2>
    <button class="back-btn" onclick="downloadCurrentLog()">&#8595; Download My Log</button>
  </div>
  <iframe id="case-frame" src="" title="Case"></iframe>
</div>

<!-- DOWNLOAD MODAL -->
<div class="modal-overlay" id="modal-overlay">
  <div class="modal">
    <h3 id="modal-title">Download Response Log</h3>
    <p id="modal-body">Your response log is ready.</p>
    <div class="modal-btn-row">
      <button class="modal-primary" id="modal-confirm">Download PDF</button>
      <button class="modal-secondary" onclick="closeModal()">Cancel</button>
    </div>
  </div>
</div>

<script>
// =====================================================================
// CASE REGISTRY
// =====================================================================
const CASES = [
  {num:1, name:"Fall with Hip Fracture", setting:"Inpatient", classification:"SSE 2 or SSE 4", taxonomy:"EE3 &mdash; Fall"},
  {num:2, name:"STEMI: Delayed Escalation", setting:"Inpatient ICU", classification:"SSE 1", taxonomy:"CM8.6 &mdash; Delayed Treatment"},
  {num:3, name:"LASA Medication Error", setting:"Medical-Surgical", classification:"SSE 5", taxonomy:"CM1 &mdash; Medication Error"},
  {num:4, name:"Heparin Overdose: NICU", setting:"Neonatal ICU", classification:"SSE 3 or SSE 4", taxonomy:"CM1 &mdash; Medication Error"},
  {num:5, name:"Wrong Patient X-Ray", setting:"Outpatient Radiology", classification:"PSE 2 or PSE 3", taxonomy:"PR2 &mdash; Wrong Patient"},
  {num:6, name:"Wrong Site Surgery", setting:"Inpatient OR", classification:"SSE 5", taxonomy:"PR1 &mdash; Wrong Body Part"},
  {num:7, name:"Time-Out Failure", setting:"Inpatient OR", classification:"SSE 5", taxonomy:"PR3 &mdash; Wrong Procedure"},
  {num:8, name:"Sponge Count Discrepancy", setting:"Inpatient OR", classification:"Near Miss (NMSE)", taxonomy:"PR4 &mdash; Retained Foreign Object (Near Miss)"},
  {num:9, name:"Home Care Burn: Heat Pack", setting:"Home Health", classification:"PSE 2", taxonomy:"EE2 &mdash; Burn"},
  {num:10, name:"LTC Fall: Volunteer Return", setting:"Long-Term Care", classification:"SSE 5", taxonomy:"EE3 &mdash; Fall"},
  {num:11, name:"Delayed Cancer Diagnosis", setting:"Ambulatory", classification:"SSE 2", taxonomy:"CM8.3/CM8.6 &mdash; Delayed Diagnosis"},
  {num:12, name:"Unnecessary Chest Tube", setting:"Emergency Department", classification:"SSE 5 or SSE 3", taxonomy:"CM8.4 &mdash; Unnecessary Procedure"},
  {num:13, name:"Morphine Overdose: Terminal Patient", setting:"Inpatient ICU", classification:"SSE 1", taxonomy:"CM1 &mdash; Medication Error"},
  {num:14, name:"Central Line Infection: Dialysis", setting:"Outpatient Dialysis", classification:"PSE 2", taxonomy:"CM11 &mdash; Healthcare Associated Infection"},
  {num:15, name:"Amniotic Fluid Embolism", setting:"Labor and Delivery", classification:"Not a Safety Event", taxonomy:"N/A"}
];

// =====================================================================
// SESSION STATE
// All response logs keyed by case number
// =====================================================================
const sessionLogs = {};
const caseStatus = {}; // 'new', 'in-progress', 'completed'
CASES.forEach(c => { caseStatus[c.num] = 'new'; sessionLogs[c.num] = null; });

// =====================================================================
// LANDING PAGE RENDER
// =====================================================================
function renderLanding(){
  const grid = document.getElementById('case-grid');
  grid.innerHTML = '';
  let done = 0;
  CASES.forEach(c => {
    const st = caseStatus[c.num];
    if(st === 'completed') done++;
    const card = document.createElement('div');
    card.className = 'case-card' + (st==='completed'?' completed':st==='in-progress'?' in-progress':'');
    card.innerHTML = `
      <div class="case-num">Case ${c.num}</div>
      <div class="case-name">${c.name}</div>
      <div class="case-meta">${c.setting}</div>
      <div class="case-meta" style="margin-top:2px;">${c.taxonomy}</div>
      ${st==='completed'?'<span class="case-badge badge-done">Completed</span>':st==='in-progress'?'<span class="case-badge badge-progress">In Progress</span>':'<span class="case-badge badge-new">Not Started</span>'}
    `;
    card.onclick = () => openCase(c.num);
    grid.appendChild(card);
  });
  document.getElementById('prog-done').textContent = done;
  document.getElementById('prog-bar').style.width = Math.round(done/15*100)+'%';
}

// =====================================================================
// OPEN / CLOSE CASE VIEWER
// =====================================================================
function openCase(num){
  const c = CASES.find(x=>x.num===num);
  document.getElementById('landing').style.display='none';
  const viewer = document.getElementById('case-viewer');
  viewer.style.display='block';
  document.getElementById('viewer-title').textContent = `Case ${num}: ${c.name}`;
  const frame = document.getElementById('case-frame');
  frame.src = `Managing_Safety_Events_Case${num}.html`;
  frame.style.height = (window.innerHeight - 60)+'px';
  if(caseStatus[num]==='new') caseStatus[num]='in-progress';
  renderLanding();

  // Listen for completion messages from the iframe
  window._currentCaseNum = num;
}

function returnToLanding(){
  document.getElementById('case-viewer').style.display='none';
  document.getElementById('landing').style.display='block';
  document.getElementById('case-frame').src='';
  window._currentCaseNum = null;
  renderLanding();
}

window.addEventListener('resize', ()=>{
  const frame = document.getElementById('case-frame');
  if(frame.src) frame.style.height = (window.innerHeight - 60)+'px';
});

// =====================================================================
// DOWNLOAD LOG: SINGLE CASE
// =====================================================================
function downloadCurrentLog(){
  const num = window._currentCaseNum;
  if(!num){ alert('No case is currently open.'); return; }
  generateAndPrintLog([num], `HCA 680 - Case ${num} Response Log`);
}

// =====================================================================
// DOWNLOAD LOG: ALL CASES
// =====================================================================
function downloadAllLogs(){
  const allNums = CASES.map(c=>c.num);
  generateAndPrintLog(allNums, 'HCA 680 - Complete Response Log (All Cases)');
}

// =====================================================================
// LOG GENERATOR
// =====================================================================
function generateAndPrintLog(caseNums, title){
  const now = new Date();
  const dateStr = now.toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'});
  const timeStr = now.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'});

  let html = `<!DOCTYPE html><html><head><meta charset="UTF-8">
<title>${title}</title>
<style>
  body{font-family:Arial,sans-serif;font-size:11pt;color:#000;margin:40px;line-height:1.5;}
  h1{font-size:16pt;margin-bottom:4px;}
  h2{font-size:13pt;margin:24px 0 8px;border-bottom:2px solid #BB0000;padding-bottom:4px;color:#BB0000;}
  h3{font-size:11pt;margin:16px 0 6px;}
  .meta{font-size:9pt;color:#555;margin-bottom:20px;}
  .section{margin-bottom:14px;}
  .section-label{font-weight:bold;font-size:9pt;text-transform:uppercase;letter-spacing:.5px;color:#555;}
  .section-value{margin-top:2px;}
  table{width:100%;border-collapse:collapse;margin-top:10px;font-size:9.5pt;}
  th{background:#000;color:#fff;padding:6px 8px;text-align:left;}
  td{border:1px solid #ddd;padding:6px 8px;vertical-align:top;}
  tr:nth-child(even) td{background:#f5f5f5;}
  .no-data{color:#888;font-style:italic;font-size:9pt;}
  .footer{margin-top:40px;font-size:8pt;color:#888;border-top:1px solid #ddd;padding-top:8px;}
  .badge{display:inline-block;padding:2px 8px;border-radius:3px;font-size:9pt;font-weight:bold;}
  .badge-completed{background:#eaf5ea;color:#2e7d32;}
  .badge-progress{background:#fff8e6;color:#b87400;}
  .badge-new{background:#f0eeeb;color:#58595b;}
  @media print{body{margin:20px;} h2{page-break-before:auto;}}
</style>
</head><body>
<h1>HCA 680: Managing Safety Events</h1>
<h1 style="font-size:13pt;font-weight:normal;margin-top:2px;">${title}</h1>
<div class="meta">Generated: ${dateStr} at ${timeStr} &nbsp;|&nbsp; Edgewood University &nbsp;|&nbsp; HCA 680: Integrity of Care &mdash; Patient Safety and Risk</div>`;

  caseNums.forEach(num => {
    const c = CASES.find(x=>x.num===num);
    const log = sessionLogs[num];
    const st = caseStatus[num];
    html += `<h2>Case ${num}: ${c.name}</h2>`;
    html += `<table><tr><th>Field</th><th>Value</th></tr>`;
    html += `<tr><td>Setting</td><td>${c.setting}</td></tr>`;
    html += `<tr><td>Taxonomy Event Type</td><td>${c.taxonomy}</td></tr>`;
    html += `<tr><td>Expected Classification</td><td>${c.classification}</td></tr>`;
    html += `<tr><td>Status</td><td><span class="badge badge-${st}">${st==='completed'?'Completed':st==='in-progress'?'In Progress':'Not Started'}</span></td></tr>`;
    if(log){
      if(log.timeOnTask) html += `<tr><td>Time on Task</td><td>${log.timeOnTask}</td></tr>`;
      if(log.startTime) html += `<tr><td>Session Started</td><td>${log.startTime}</td></tr>`;
      if(log.endTime) html += `<tr><td>Session Ended</td><td>${log.endTime}</td></tr>`;
      html += `</table>`;
      if(log.responses && log.responses.length > 0){
        html += `<h3>Discussion Point Responses</h3><table><tr><th>Step</th><th>Question</th><th>Your Selection</th><th>Feedback Received</th></tr>`;
        log.responses.forEach(r => {
          html += `<tr><td>${r.step||''}</td><td>${r.question||''}</td><td>${r.selected||''}</td><td>${r.feedback||''}</td></tr>`;
        });
        html += `</table>`;
      }
      if(log.finalClassification){
        html += `<h3>Final Classification</h3><table>`;
        html += `<tr><td>SEC Classification</td><td>${log.finalClassification||'Not recorded'}</td></tr>`;
        if(log.sentinelEvent!==undefined) html += `<tr><td>Sentinel Event?</td><td>${log.sentinelEvent}</td></tr>`;
        if(log.sacScore) html += `<tr><td>SAC Matrix Score</td><td>${log.sacScore}</td></tr>`;
        if(log.managerUpdateRequested!==undefined) html += `<tr><td>Manager Update Requested?</td><td>${log.managerUpdateRequested?'Yes':'No'}</td></tr>`;
        html += `</table>`;
      }
    } else {
      html += `</table><p class="no-data">No response data recorded for this case. ${st==='new'?'This case has not been started.':'Complete the case to record responses.'}</p>`;
    }
  });

  html += `<div class="footer">This log was automatically generated by the HCA 680 Managing Safety Events tool and reflects responses recorded during the current browser session. &copy; Edgewood University.</div></body></html>`;

  const win = window.open('','_blank','width=900,height=700');
  if(!win){ alert('Please allow pop-ups to download your log.'); return; }
  win.document.write(html);
  win.document.close();
  setTimeout(()=>{ win.focus(); win.print(); }, 600);
}

// =====================================================================
// RECEIVE MESSAGES FROM IFRAMES
// Cases can post messages to signal completion and send log data
// =====================================================================
window.addEventListener('message', function(event){
  const d = event.data;
  if(!d || typeof d !== 'object') return;
  const num = window._currentCaseNum;
  if(!num) return;

  if(d.type === 'case-complete'){
    caseStatus[num] = 'completed';
    sessionLogs[num] = d.log || {};
    renderLanding();
  }
  if(d.type === 'case-progress'){
    if(caseStatus[num] !== 'completed') caseStatus[num] = 'in-progress';
    if(!sessionLogs[num]) sessionLogs[num] = {};
    Object.assign(sessionLogs[num], d.log || {});
  }
});

// =====================================================================
// MODAL HELPERS
// =====================================================================
function closeModal(){ document.getElementById('modal-overlay').classList.remove('show'); }

// =====================================================================
// INIT
// =====================================================================
renderLanding();
</script>
</body>
</html>
